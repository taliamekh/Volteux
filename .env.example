# Anthropic — Sonnet 4.6 generation + Haiku 4.5 classifier (Units 7, 8, 10)
# Use a separate dev key with a $5/day usage alert; production key (v0.2 deploy) MUST be a different key.
ANTHROPIC_API_KEY=

# Compile API — used by pipeline/gates/compile.ts (Unit 6) and the local Hono server.
# In v0.1 the server runs locally via `bun run compile:up` (Docker); URL defaults to http://localhost:8787.
COMPILE_API_URL=http://localhost:8787

# Compile API bearer secret. The server REFUSES TO START unless this is at least 32 bytes
# (64 hex chars or equivalent base64). Generate with: openssl rand -hex 32
# Use a different value for every environment (local dev, v0.2 Hetzner box, etc.).
COMPILE_API_SECRET=
