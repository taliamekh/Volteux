{
  "name": "volteux",
  "version": "0.1.0-pipeline",
  "description": "AI-powered Arduino starter kit web tool — pipeline track (Track 2 / Kai)",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "gen:schema": "bun schemas/generate-json-schema.ts",
    "verify:schema-current": "bun schemas/generate-json-schema.ts --check",
    "compile:build": "docker build -f infra/Dockerfile -t volteux-compile .",
    "compile:up": "docker run --rm -p 8787:8787 -e COMPILE_API_SECRET=\"$COMPILE_API_SECRET\" volteux-compile",
    "compile:server": "bun run infra/server/compile-api.ts",
    "measure:prompt-tokens": "bun scripts/measure-prompt-tokens.ts",
    "smoke": "bun scripts/v01-pipeline-io-smoke.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "~0.91.1",
    "@hono/zod-validator": "^0.4",
    "hono": "^4",
    "p-limit": "^7",
    "zod": "^3",
    "zod-to-json-schema": "^3.25.2"
  }
}
